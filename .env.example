# Copy to .env for docker compose
POSTGRES_USER=medextract
POSTGRES_PASSWORD=medextract
POSTGRES_DB=medextract
DATABASE_URL=postgresql+psycopg://medextract:medextract@db:5432/medextract

# Host-side ports (defaults chosen to avoid clashing with other local services
# on 5432/8000/3000; container-internal ports are unchanged)
POSTGRES_PORT=5433
BACKEND_PORT=8010
FRONTEND_PORT=3100

NEXT_PUBLIC_API_URL=http://localhost:8010
CORS_ORIGINS=http://localhost:3100
